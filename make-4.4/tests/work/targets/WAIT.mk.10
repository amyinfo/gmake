
all : p1 .WAIT np1

p1: pre1 pre2
pre1: ; @/usr/bin/perl /home/kyra/workplace/go/make/make-4.4/tests/../tests/thelp.pl -q out start-$@ file PRE1 wait PRE2 out end-$@
pre2: ; @/usr/bin/perl /home/kyra/workplace/go/make/make-4.4/tests/../tests/thelp.pl -q wait PRE1 out $@ file PRE2


np1: npre1 npre2
npre1: ; @/usr/bin/perl /home/kyra/workplace/go/make/make-4.4/tests/../tests/thelp.pl -q out start-$@ sleep 1 out end-$@
npre2: ; @/usr/bin/perl /home/kyra/workplace/go/make/make-4.4/tests/../tests/thelp.pl -q out $@

.NOTPARALLEL: np1

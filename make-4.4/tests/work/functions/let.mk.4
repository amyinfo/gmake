
auto_var = \
  udef \
  CC \
  FOOFOO \
  MAKE \
  foo \
  CFLAGS \
  WHITE \
  @ \
  <
av = $(foreach var, $(auto_var), $(origin $(var)) )
foo = bletch null @ garf
override WHITE := BLACK

define mktarget
target: foo := $(foo)
target: ; @echo $(AR)_$(foo)_
endef

all: auto target
auto: ; @echo $(let $(auto_var),,$(av)) $(av)
$(let AR foo,bar foo ,$(eval $(value mktarget)))

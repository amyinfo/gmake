endif

ifneq ($(realpath /./),/)
  $(warning $(realpath /./) != /)
endif

ifneq ($(realpath /.///),/)
  $(warning $(realpath /.///) != /)
endif

ifneq ($(realpath /..),/)
  $(warning $(realpath /..) != /)
endif

